	(text "VSHUNT = 0 at rest; +Z actuation\n\n1. MCU provides current setpoint; I_set = Vref / R_shunt for +Z actuation.\n2. Vref - VSHUNT > GND => op-amp drives output HIGH.\n3. HIGH => NPN conducts, PNP open; VDD -> through VCA -> GND;\n4. VSHUNT = I*R_Shunt updates; op-amp output adjusted till Vref ~= VSHUNT\n\nFor -Z actuation;\n1. MCU Vref < 0; Vref - VSHUNT < 0 => op-amp outut driven LOW.\n2. LOW => PNP conducts, NPN open; GND -> through VCA -> -VDD\n3. VSHUNT = I*R_Shunt updates; op-amp output adjusted till Vref ~= VSHUNT\n"
		(exclude_from_sim no)
		(at 177.038 151.13 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "2b60d399-0e9c-43a5-8fdb-86cc3de2fb11")
	)
